# AI API key (required). Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# MongoDB connection (server-side only; never expose to the browser).
# Atlas example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
MONGODB_URI=
MONGODB_DB=brim

# development or production
APP_ENV=development

# Shared secret required in the `X-API-Key` header to call /ingest and /query.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank ONLY for local dev; in production an empty key disables those
# endpoints (fail-closed).
API_KEY=

# Max upload size in megabytes
MAX_FILE_SIZE_MB=50

# Comma-separated CORS origins, e.g. https://app.example.com,https://admin.example.com
# Leave blank to block all cross-origin browser requests.
ALLOWED_ORIGINS=

# Comma-separated allowed Host headers (e.g. api.example.com). Blank = allow any.
ALLOWED_HOSTS=

# Set to true ONLY when running behind a trusted reverse proxy that sets
# X-Forwarded-For. Otherwise clients could spoof their IP to dodge rate limits.
TRUST_PROXY_FORWARDED=false

# Hard cap on paid AI API calls per UTC day across all clients (0 = unlimited).
GEMINI_DAILY_LIMIT=0

# Rate limits (slowapi syntax)
RATE_LIMIT_INGEST=10/minute
RATE_LIMIT_QUERY=30/minute
RATE_LIMIT_DEFAULT=120/minute

# Max jobs kept in the in-memory store
MAX_JOBS=1000

# Max characters allowed in a question
MAX_QUESTION_LENGTH=4000
