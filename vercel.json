{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "app/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app/main.py" },
    { "src": "/health", "dest": "app/main.py" },
    { "src": "/ingest", "dest": "app/main.py" },
    { "src": "/query", "dest": "app/main.py" },
    { "src": "/assets/(.*)", "dest": "frontend/dist/assets/$1" },
    { "src": "/index.html", "dest": "frontend/dist/index.html" },
    { "src": "/(.*)", "dest": "frontend/dist/index.html" }
  ]
}
