{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm --prefix frontend ci && npm --prefix frontend run build",
  "installCommand": "npm --prefix frontend ci",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/gemini", "destination": "/api/gemini" },
    { "source": "/api/:path*", "destination": "http://149.248.54.32/api/:path*" },
    { "source": "/health", "destination": "http://149.248.54.32/health" },
    { "source": "/ingest", "destination": "http://149.248.54.32/ingest" },
    { "source": "/query", "destination": "http://149.248.54.32/query" }
  ]
}
